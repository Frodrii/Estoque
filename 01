<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>📦 Gerenciador de Itens por Palete</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        * { box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }
        .glass-effect {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        .fade-in {
            animation: fadeIn 0.3s ease-in;
        }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        .spin {
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        .table-row-hover:hover {
            background-color: rgba(102, 126, 234, 0.05);
            transition: background-color 0.2s ease;
        }
        .filter-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 12px;
            background: #e0e7ff;
            color: #4f46e5;
            border-radius: 20px;
            font-size: 0.875rem;
            font-weight: 500;
        }
        .filter-badge button {
            background: none;
            border: none;
            cursor: pointer;
            padding: 0;
            display: flex;
            align-items: center;
            color: #4f46e5;
        }
        .filter-badge button:hover {
            opacity: 0.7;
        }
    </style>
</head>
<body class="bg-gray-50">
    <div class="min-h-screen py-8 px-4 sm:px-6 lg:px-8">
        <div class="max-w-7xl mx-auto">
            <!-- Header -->
            <div class="mb-8 fade-in">
                <div class="flex items-center justify-between mb-2">
                    <h1 class="text-4xl font-bold text-gray-900 flex items-center gap-3">
                        <svg class="w-10 h-10 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m0 0l8 4m-8-4v10l8 4m0-10l8 4m-8-4v10l8 4M7 12l8 4m0 0l8-4"></path>
                        </svg>
                        Gerenciador de Paletes
                    </h1>
                    <div id="stats" class="bg-indigo-100 text-indigo-800 px-4 py-2 rounded-full font-semibold">
                        0 itens
                    </div>
                </div>
                <p class="text-gray-600">Visualize e gerencie seus itens organizados por palete</p>
            </div>

            <!-- Filters Section -->
            <div class="glass-effect rounded-xl shadow-lg p-6 mb-8 fade-in">
                <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path>
                    </svg>
                    Filtros
                </h2>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
                    <!-- Search Input -->
                    <div>
                        <label for="busca" class="block text-sm font-medium text-gray-700 mb-2">
                            🔍 Buscar
                        </label>
                        <input 
                            type="text" 
                            id="busca" 
                            placeholder="Código, produto ou palete..." 
                            autocomplete="off"
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none transition"
                        >
                    </div>

                    <!-- Date Filter -->
                    <div>
                        <label for="mesAnoValidade" class="block text-sm font-medium text-gray-700 mb-2">
                            📅 Validade (Mês/Ano)
                        </label>
                        <select 
                            id="mesAnoValidade"
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none transition"
                        >
                            <option value="todos">Todos os períodos</option>
                        </select>
                    </div>

                    <!-- Location Type Filter -->
                    <div>
                        <label for="tipoLocal" class="block text-sm font-medium text-gray-700 mb-2">
                            ❄️ Tipo de Local
                        </label>
                        <select 
                            id="tipoLocal"
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none transition"
                        >
                            <option value="todos">Todos</option>
                            <option value="congelada">Congelada (F01-F04, SORVETE)</option>
                            <option value="refrigerada">Refrigerada (IF, PF, etc.)</option>
                        </select>
                    </div>
                </div>

                <!-- Active Filters Display -->
                <div id="filtrosAtivos" class="flex flex-wrap gap-2 mb-4"></div>

                <!-- Clear Filters Button -->
                <button 
                    id="btnLimparFiltros"
                    class="px-4 py-2 bg-gray-200 hover:bg-gray-300 text-gray-800 rounded-lg font-medium transition flex items-center gap-2"
                >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                    Limpar Filtros
                </button>
            </div>

            <!-- Status/Loading Section -->
            <div id="status" class="mb-8"></div>

            <!-- Content Section -->
            <div id="conteudo" class="space-y-6"></div>
        </div>
    </div>

    <script>
        // ============================================
        // CONFIGURAÇÕES
        // ============================================
        const SHEET_ID = '1sxetmK0BUCeh1mk-_cGxESgn7XJSiVQ9R0UQQtXAEEY';
        const SHEET_NAME = 'DadosLimpos';
        const API_URL = `https://opensheet.elk.sh/${SHEET_ID}/${SHEET_NAME}`;

        const COLUNAS = {
            codigo: 'Codigo',
            produto: 'Produto',
            palete: 'Palete',
            qtde: 'Qtde Esperada',
            validade: 'Validade',
            dataEntrada: 'Data Entrada',
            recebimento: 'Recebimento',
            local: 'Locais vinculados'
        };

        // ============================================
        // ESTADO GLOBAL
        // ============================================
        let dadosOriginais = [];
        let itensFiltrados = [];
        const estadoFiltros = {
            busca: '',
            mesAno: 'todos',
            tipoLocal: 'todos'
        };

        // ============================================
        // ELEMENTOS DO DOM
        // ============================================
        const statusDiv = document.getElementById('status');
        const conteudoDiv = document.getElementById('conteudo');
        const buscaInput = document.getElementById('busca');
        const mesAnoSelect = document.getElementById('mesAnoValidade');
        const tipoLocalSelect = document.getElementById('tipoLocal');
        const statsSpan = document.getElementById('stats');
        const filtrosAtivosDiv = document.getElementById('filtrosAtivos');
        const btnLimparFiltros = document.getElementById('btnLimparFiltros');

        // ============================================
        // FUNÇÕES UTILITÁRIAS
        // ============================================
        function classificarLocal(localStr) {
            if (!localStr) return 'refrigerada';
            const local = localStr.toUpperCase();
            if (local.startsWith('F01') || local.startsWith('F02') || local.startsWith('F03') || local.startsWith('F04') || local.includes('SORVETE')) {
                return 'congelada';
            }
            return 'refrigerada';
        }

        function mostrarCarregamento() {
            statusDiv.innerHTML = `
                <div class="flex items-center justify-center p-8">
                    <div class="text-center">
                        <div class="inline-block">
                            <svg class="w-12 h-12 text-indigo-600 spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                            </svg>
                        </div>
                        <p class="mt-4 text-gray-600 font-medium">Carregando dados...</p>
                    </div>
                </div>
            `;
        }

        function mostrarErro(mensagem) {
            statusDiv.innerHTML = `
                <div class="bg-red-50 border border-red-200 rounded-lg p-6 flex items-start gap-4">
                    <svg class="w-6 h-6 text-red-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <div>
                        <h3 class="font-semibold text-red-900">Erro ao carregar dados</h3>
                        <p class="text-red-700 text-sm mt-1">${mensagem}</p>
                    </div>
                </div>
            `;
            statusDiv.style.display = 'block';
        }

        function atualizarFiltrosAtivos() {
            filtrosAtivosDiv.innerHTML = '';
            
            if (estadoFiltros.busca) {
                const badge = document.createElement('div');
                badge.className = 'filter-badge';
                badge.innerHTML = `
                    <span>🔍 "${estadoFiltros.busca}"</span>
                    <button onclick="limparFiltro('busca')" title="Remover filtro">×</button>
                `;
                filtrosAtivosDiv.appendChild(badge);
            }

            if (estadoFiltros.mesAno !== 'todos') {
                const badge = document.createElement('div');
                badge.className = 'filter-badge';
                badge.innerHTML = `
                    <span>📅 ${estadoFiltros.mesAno}</span>
                    <button onclick="limparFiltro('mesAno')" title="Remover filtro">×</button>
                `;
                filtrosAtivosDiv.appendChild(badge);
            }

            if (estadoFiltros.tipoLocal !== 'todos') {
                const label = estadoFiltros.tipoLocal === 'congelada' ? '❄️ Congelada' : '🧊 Refrigerada';
                const badge = document.createElement('div');
                badge.className = 'filter-badge';
                badge.innerHTML = `
                    <span>${label}</span>
                    <button onclick="limparFiltro('tipoLocal')" title="Remover filtro">×</button>
                `;
                filtrosAtivosDiv.appendChild(badge);
            }
        }

        function limparFiltro(tipo) {
            if (tipo === 'busca') {
                buscaInput.value = '';
                estadoFiltros.busca = '';
            } else if (tipo === 'mesAno') {
                mesAnoSelect.value = 'todos';
                estadoFiltros.mesAno = 'todos';
            } else if (tipo === 'tipoLocal') {
                tipoLocalSelect.value = 'todos';
                estadoFiltros.tipoLocal = 'todos';
            }
            aplicarFiltros();
        }

        // ============================================
        // CARREGAMENTO DE DADOS
        // ============================================
        async function carregarDados() {
            mostrarCarregamento();
            try {
                const response = await fetch(API_URL);
                if (!response.ok) throw new Error(`Erro HTTP: ${response.status}`);
                
                dadosOriginais = await response.json();
                if (dadosOriginais.length === 0) throw new Error('Nenhum dado encontrado na planilha');

                // Popula o filtro de mês/ano
                const mesesAnos = new Set();
                dadosOriginais.forEach(item => {
                    const validade = item[COLUNAS.validade];
                    if (validade) {
                        const partes = validade.split('/');
                        if (partes.length === 3) {
                            mesesAnos.add(`${partes[1]}/${partes[2]}`);
                        }
                    }
                });

                const mesesAnosArray = Array.from(mesesAnos).sort((a, b) => {
                    const [mesA, anoA] = a.split('/');
                    const [mesB, anoB] = b.split('/');
                    if (anoA !== anoB) return anoA - anoB;
                    return mesA - mesB;
                });

                mesesAnosArray.forEach(mesAno => {
                    const option = document.createElement('option');
                    option.value = mesAno;
                    option.textContent = mesAno;
                    mesAnoSelect.appendChild(option);
                });

                statusDiv.style.display = 'none';
                aplicarFiltros();
                
            } catch (error) {
                mostrarErro(error.message);
            }
        }

        // ============================================
        // FILTROS E RENDERIZAÇÃO
        // ============================================
        function aplicarFiltros() {
            const termoBusca = buscaInput.value.trim().toLowerCase();
            const mesAnoSelecionado = mesAnoSelect.value;
            const tipoLocalSelecionado = tipoLocalSelect.value;

            // Atualizar estado
            estadoFiltros.busca = termoBusca;
            estadoFiltros.mesAno = mesAnoSelecionado;
            estadoFiltros.tipoLocal = tipoLocalSelecionado;

            itensFiltrados = dadosOriginais.filter(item => {
                // Filtro por mês/ano
                if (mesAnoSelecionado !== 'todos') {
                    const validade = item[COLUNAS.validade] || '';
                    const partes = validade.split('/');
                    if (partes.length === 3) {
                        const mesAno = `${partes[1]}/${partes[2]}`;
                        if (mesAno !== mesAnoSelecionado) return false;
                    } else {
                        return false;
                    }
                }

                // Filtro por tipo de local
                if (tipoLocalSelecionado !== 'todos') {
                    const local = item[COLUNAS.local] || '';
                    const categoria = classificarLocal(local);
                    if (categoria !== tipoLocalSelecionado) return false;
                }

                // Filtro por busca textual
                if (termoBusca !== '') {
                    const codigo = (item[COLUNAS.codigo] || '').toString().toLowerCase();
                    const produto = (item[COLUNAS.produto] || '').toLowerCase();
                    const palete = (item[COLUNAS.palete] || '').toString().toLowerCase();
                    return codigo.includes(termoBusca) || produto.includes(termoBusca) || palete.includes(termoBusca);
                }

                return true;
            });

            atualizarFiltrosAtivos();
            atualizarStats();
            renderizar();
        }

        function atualizarStats() {
            statsSpan.textContent = `${itensFiltrados.length} itens`;
        }

        function renderizar() {
            if (itensFiltrados.length === 0) {
                conteudoDiv.innerHTML = `
                    <div class="text-center py-12">
                        <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path>
                        </svg>
                        <p class="text-gray-500 text-lg font-medium">Nenhum item encontrado</p>
                        <p class="text-gray-400 text-sm mt-2">Tente ajustar seus filtros</p>
                    </div>
                `;
                return;
            }

            // Agrupa por palete
            const paletes = {};
            itensFiltrados.forEach(item => {
                const numPalete = item[COLUNAS.palete] || 'SEM PALETE';
                if (!paletes[numPalete]) paletes[numPalete] = [];
                paletes[numPalete].push(item);
            });

            // Ordena paletes numericamente
            const paletesOrdenados = Object.keys(paletes).sort((a, b) => 
                a.localeCompare(b, undefined, { numeric: true })
            );

            let html = '';
            paletesOrdenados.forEach(num => {
                const itens = paletes[num];
                html += `
                    <div class="glass-effect rounded-xl shadow-lg overflow-hidden fade-in">
                        <div class="bg-gradient-to-r from-indigo-600 to-indigo-700 px-6 py-4">
                            <h3 class="text-xl font-bold text-white flex items-center gap-2">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m0 0l8 4m-8-4v10l8 4m0-10l8 4m-8-4v10l8 4M7 12l8 4m0 0l8-4"></path>
                                </svg>
                                Palete ${num}
                            </h3>
                            <p class="text-indigo-100 text-sm mt-1">${itens.length} item(ns)</p>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full">
                                <thead class="bg-gray-50 border-b border-gray-200">
                                    <tr>
                                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Código</th>
                                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Produto</th>
                                        <th class="px-6 py-3 text-right text-xs font-semibold text-gray-700 uppercase tracking-wider">Qtde</th>
                                        <th class="px-6 py-3 text-center text-xs font-semibold text-gray-700 uppercase tracking-wider">Validade</th>
                                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Entrada</th>
                                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Recebimento</th>
                                        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Local</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-200">
                `;

                itens.forEach((item, index) => {
                    const localClassificado = classificarLocal(item[COLUNAS.local] || '');
                    const localBadge = localClassificado === 'congelada' 
                        ? '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">❄️ Congelada</span>'
                        : '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-cyan-100 text-cyan-800">🧊 Refrigerada</span>';
                    
                    html += `
                        <tr class="table-row-hover">
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-mono font-semibold text-indigo-600">${item[COLUNAS.codigo] || '-'}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">${item[COLUNAS.produto] || '-'}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900 text-right">${item[COLUNAS.qtde] || '0'}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 text-center">${item[COLUNAS.validade] || '-'}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">${item[COLUNAS.dataEntrada] || '-'}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">${item[COLUNAS.recebimento] || '-'}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">${localBadge}</td>
                        </tr>
                    `;
                });

                html += `
                                </tbody>
                            </table>
                        </div>
                    </div>
                `;
            });

            conteudoDiv.innerHTML = html;
        }

        // ============================================
        // EVENT LISTENERS
        // ============================================
        buscaInput.addEventListener('input', () => {
            // Debounce para evitar muitas chamadas
            clearTimeout(buscaInput.debounceTimer);
            buscaInput.debounceTimer = setTimeout(aplicarFiltros, 300);
        });

        mesAnoSelect.addEventListener('change', aplicarFiltros);
        tipoLocalSelect.addEventListener('change', aplicarFiltros);
        btnLimparFiltros.addEventListener('click', () => {
            buscaInput.value = '';
            mesAnoSelect.value = 'todos';
            tipoLocalSelect.value = 'todos';
            aplicarFiltros();
        });

        // ============================================
        // INICIALIZAÇÃO
        // ============================================
        document.addEventListener('DOMContentLoaded', carregarDados);
    </script>
</body>
</html>